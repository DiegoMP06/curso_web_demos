---
import { Icon } from "astro-icon/components";
import CartPopover from "../cart/CartPopover.vue";

const isHomePage = Astro.url.pathname === "/";
---

<header class="bg-blue-700 fixed w-full top-0 left-0 right-0 z-40" id="header">
    <div class="mx-auto max-w-4xl flex gap-4 justify-between items-center p-4">
        <p class="text-2xl text-white">
            Moda<span class="font-bold">Tech</span>
        </p>

        <nav class="flex items-center gap-3">
            {isHomePage && <CartPopover client:load />}

            <a
                href={isHomePage ? "/products" : `/`}
                class="px-2 py-1 rounded-xl bg-white text-blue-700 font-bold hover:bg-blue-50 transition-colors"
            >
                {isHomePage ? "Productos" : "Inicio"}
            </a>
        </nav>
    </div>
</header>

<div id="header-placeholder"></div>

<script>
    function updateHeaderHeight() {
        const header = document.querySelector("#header") as HTMLDivElement;
        const headerPlaceholder = document.querySelector(
            "#header-placeholder",
        ) as HTMLDivElement;

        if (header && headerPlaceholder) {
            const headerHeight = header.getBoundingClientRect().height;
            headerPlaceholder.style.height = `${headerHeight}px`;
        }
    }

    document.addEventListener("astro:page-load", updateHeaderHeight);
    document.addEventListener("astro:after-swap", updateHeaderHeight);
    window.addEventListener("resize", updateHeaderHeight);
</script>
