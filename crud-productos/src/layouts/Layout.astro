---
import "../styles/global.css";
import "sweetalert2/dist/sweetalert2.min.css";

import { ClientRouter } from "astro:transitions";
import { Toaster } from "sonner";

import Hero from "../components/ui/Hero.astro";
import Header from "../components/ui/Header.astro";

const isHomePage = Astro.url.pathname === "/";
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />

        <ClientRouter />

        <title>CRUD Productos</title>
    </head>
    <body class="bg-gray-100 flex min-h-screen flex-col">
        <Header />

        {isHomePage && <Hero />}

        <main class="max-w-4xl w-full mx-auto px-4 py-10 flex-1">
            <slot />
        </main>

        <footer class="p-4">
            <p class="text-center text-sm text-gray-400 font-semibold">
                Todos los derechos reservados &copy; {new Date().getFullYear()} ModaTech.
                Diseñado y desarrollado por Diego Meneses Perez.
            </p>
        </footer>

        <Toaster client:load richColors position="top-right" />
    </body>
</html>
